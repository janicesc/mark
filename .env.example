# Supabase (get these from Project Settings > API in Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Stripe (get these from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret (from Stripe Dashboard → Developers → Webhooks → Add endpoint → Signing secret)
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: use Products/Prices from Dashboard so the correct image shows in Checkout.
# With one Product you can only have one image. For Light + Dark, create two Products (each with one image) and set:
STRIPE_PRICE_ID_LIGHT=
STRIPE_PRICE_ID_DARK=
# Legacy: single Price ID (image will be the same for both finishes)
STRIPE_PRICE_ID=
STRIPE_PRODUCT_ID=
# Base URL for redirects (e.g. http://localhost:3000 in dev, https://yoursite.com in prod)
NEXT_PUBLIC_APP_URL=http://localhost:3000
