# Supabase (get these from Project Settings > API in Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Stripe (get these from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
# Optional: create a Product + Price in Dashboard and set the Price ID for consistency
STRIPE_PRICE_ID=
# Base URL for redirects (e.g. http://localhost:3000 in dev, https://yoursite.com in prod)
NEXT_PUBLIC_APP_URL=http://localhost:3000
